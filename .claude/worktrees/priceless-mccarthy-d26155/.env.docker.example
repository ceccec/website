# Copy to `.env.docker` (see `.gitignore`) and set at least `PAYLOAD_SECRET`.
# Docker Compose loads this for the `app` service. The compose file also sets Mongo, MinIO (S3), Mailpit (SMTP), and public URLs so the stack does not require Vercel Blob or SendGrid.
#
# Optional third-party keys — only if you use those features (e.g. Stripe in Admin); not required for a self-contained deploy.

PAYLOAD_SECRET=

# Optional — match `MINIO_ROOT_*` in your project `.env` if you override MinIO credentials.
# MINIO_ROOT_USER=
# MINIO_ROOT_PASSWORD=

# Optional integrations (see root `.env.example`)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
