# =============================================================================
# Copy to `.env` for Next.js + Payload local dev and hosts that load dotenv.
#
# • Deploy wizard: `config/cloudflare.bindings.json` → `package.json` `cloudflare.bindings`
#   (pnpm sync:cloudflare-bindings). D1/R2: `wrangler.jsonc`. Full env: `config/cloudflare-env-reference.md`.
# • Worker / Wrangler secrets template: `.dev.vars.example` → `.dev.vars`.
# • Stack detection: `src/lib/deploymentTarget.ts`.
#
# Cloudflare: set sensitive values in Worker **Variables & Secrets** and duplicate
# build-time secrets under **Settings → Builds → Build variables and secrets**
# ([Workers Builds configuration](https://developers.cloudflare.com/workers/ci-cd/builds/configuration/)).
#
# Build-time secrets: see root README (**Deploy → This repository**) and DEPLOYMENT.md.
# Optional env catalog for this codebase: `config/cloudflare-env-reference.md`.
# =============================================================================

# --- Stack ---
# Full Docker stack (Mongo + MinIO + Mailpit + Nginx): `docker-compose.yml`, `Dockerfile`, `docker/` — see DOCKER.md & docker/CONVENTIONS.md.
# App listens only on a Unix socket; Nginx terminates HTTP. Copy `.env.docker.example` → `.env.docker`.
# Set `HTTP_PORT` / `NEXT_PUBLIC_SITE_URL` in a project `.env` or the shell; rebuild `app` after changing NEXT_PUBLIC_*.
# Optional local doc search (Node + Debian ripgrep in the image): `LOCAL_DOC_SEARCH_ROOT` + build flag `NEXT_PUBLIC_LOCAL_DOC_SEARCH` (compose defaults differ from Dockerfile for Vercel/CF compatibility).
# LOCAL_DOC_SEARCH_ROOT=
# Stand-alone Mongo only (no app container): `MONGODB_URL=mongodb://127.0.0.1:27018/payload`, `PAYLOAD_HOSTING=vercel`,
# unset postgres URLs so Mongo wins in `src/lib/payloadDB.ts`.
PAYLOAD_HOSTING=
POSTGRES_URL=
DATABASE_URL=
# Optional: `mongodb` — see `src/lib/payloadDB.ts` (`templates/with-vercel-mongodb`). Incompatible with Cloudflare Workers.
PAYLOAD_DB_ADAPTER=
MONGODB_URL=
# Optional: `true` — multi-tenant plugin on `pages` only (`examples/multi-tenant`). Run `payload migrate`, assign tenants in admin, then `payload generate:types`.
PAYLOAD_MULTI_TENANT=
# Optional: `true` — ecommerce plugin (beta; `templates/ecommerce`). Run `payload migrate` then `payload generate:types`; add Stripe adapters when you need checkout.
PAYLOAD_ECOMMERCE=
# Optional: `true` only with `PAYLOAD_ECOMMERCE` — enables product variants (extra collections; migrate after enabling).
PAYLOAD_ECOMMERCE_VARIANTS=
# Optional: `true` enables `@payloadcms/plugin-mcp`. Options: `src/plugins/mcp/config.ts` (`MCPPluginConfig`). Docs: https://payloadcms.com/docs/plugins/mcp
PAYLOAD_MCP=
# Optional slices — `false` disables a schema bundle (`src/plugins/env.ts`, `src/plugins/schema/`).
# PAYLOAD_TEMPLATE_MARKETING=
# PAYLOAD_TEMPLATE_DOCS=
# PAYLOAD_TEMPLATE_PARTNERS=
# PAYLOAD_TEMPLATE_RELEASE_AUTOMATION=

# --- Payload ---
PAYLOAD_SECRET=
PAYLOAD_LOG_LEVEL=
PAYLOAD_CORS_ORIGINS=

# Admin chrome (`examples/whitelabel`) — optional
PAYLOAD_ADMIN_TITLE_SUFFIX=
PAYLOAD_ADMIN_META_DESCRIPTION=
PAYLOAD_ADMIN_FAVICON_URL=

# Public URL stack — serverURL, CSRF, OG, sitemap (`templates/website`, `templates/with-vercel-website`, `examples/auth`)
PAYLOAD_PUBLIC_APP_URL=

# --- URLs (public / inlined where NEXT_PUBLIC_*) ---
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SERVER_URL=
NEXT_PUBLIC_CMS_URL=
# Reachable origin for Payload Cloud GraphQL (`/api/graphql`). Same host cookies expect this origin.
# Local site-only dev: use NEXT_PUBLIC_OMIT_CLOUD_ERRORS=true so the frontend does not call Cloud on load.
# Otherwise run the Cloud API (or tunnel) at this URL — e.g. http://localhost:8001 only works if a server listens there.
NEXT_PUBLIC_CLOUD_CMS_URL=http://cloud.local.payloadcms.com:8001

NEXT_PUBLIC_IMAGE_REMOTE_HOSTS=
# Default: leave empty — standard Next.js `next/image` (works everywhere). Set `true` only on Cloudflare when Image transformations are enabled on the zone and hostname matches `NEXT_PUBLIC_SITE_URL`.
NEXT_PUBLIC_CF_IMAGE_RESIZING=

# Draft preview: secret must match `secret` query param on `GET /api/preview` (see `src/app/(frontend)/api/preview/route.ts`).
# Generate a long random string locally; never commit real secrets. Used with Payload draft mode / live preview entrypoints.
# On-demand revalidation (separate from draft cookie flow):
NEXT_PRIVATE_DRAFT_SECRET=
NEXT_PRIVATE_REVALIdATION_KEY=

# GitHub (generate:llms, docs, contributions). For `pnpm generate:llms` in CI without a token, commit
# `public/llms.txt` + `public/llms-full.txt` so the script can skip the GitHub fetch.
GITHUB_ACCESS_TOKEN=

# Algolia — Docsearch (marketing). Same value can be set in Admin → Public site settings.
NEXT_PUBLIC_ALGOLIA_DOCSEARCH_KEY=

# Analytics & pixels (public)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_MEASUREMENT_ID=
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=
NEXT_PUBLIC_IS_LIVE=

# GitHub OAuth (cloud onboarding)
NEXT_PUBLIC_GITHUB_REDIRECT_URI=http://local.payloadcms.com:3000/gh
NEXT_PUBLIC_GITHUB_CLIENT_ID=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Optional for `@payloadcms/plugin-ecommerce` Stripe adapter (`/api/payments/stripe/webhooks`). Alias: `STRIPE_WEBHOOKS_SIGNING_SECRET`.
STRIPE_WEBHOOK_SECRET=

DISCORD_TOKEN=
DISCORD_SCRAPE_CHANNEL_ID=

# Algolia — community help
NEXT_PUBLIC_ALGOLIA_CH_ID=
NEXT_PUBLIC_ALGOLIA_PUBLIC_KEY=
NEXT_PRIVATE_ALGOLIA_API_KEY=
NEXT_PUBLIC_ALGOLIA_CH_INDEX_NAME=

SITEMAP_URL=

# Bearer or ?secret= — `/api/sync-ch`, `/api/sync-algolia`; Vercel Cron sends Authorization when CRON_SECRET is set
NEXT_PRIVATE_CRON_KEY=
# Same purpose as NEXT_PRIVATE_CRON_KEY — Payload jobs cron (`templates/website`) + sync routes
CRON_SECRET=

NEXT_PUBLIC_NEWSLETTER_FORM_ID=

NEXT_PUBLIC_SKIP_BUILD_DOCS=
NEXT_PUBLIC_SKIP_BUILD_HELPS=

# Docs — local paths / flags / automation
DOCS_DIR_V2=../payload/docs
DOCS_DIR_V3=../payload/docs
NEXT_PUBLIC_ENABLE_BETA_DOCS=
NEXT_PUBLIC_ENABLE_LEGACY_DOCS=
COMMIT_DOCS_API_URL=
COMMIT_DOCS_API_KEY=

# When true: skip Payload Cloud session fetch on load (no network); login/account features need Cloud URL + false.
NEXT_PUBLIC_OMIT_CLOUD_ERRORS=false

VERCEL_REDEPLOY_URL=

PAYLOAD_RELEASE_SECRET=

NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
NEXT_PRIVATE_RECAPTCHA_SECRET_KEY=

# Vercel Blob — Postgres path only (omit on Cloudflare R2)
BLOB_READ_WRITE_TOKEN=

# Wrangler local tooling (optional)
# CLOUDFLARE_ENV=
# CLOUDFLARE_REMOTE_BINDINGS=

# Email / CRM
SENDGRId_API_KEY=
NEXT_PRIVATE_HUBSPOT_PORTAL_KEY=

# Auth cookies (`collections/Users`)
COOKIE_DOMAIN=
DISABLE_SECURE_COOKIE=

# Server analytics API (`src/app/api/analytics`)
GA_USE_DEMO_DATA=
GA_PROPERTY_ID=
GA_CREDENTIALS=

# Scripts (`fetchGitHub.ts`, etc.)
SYNC_BATCH_LIMIT=

# Bundle analyzer (`pnpm analyze`)
ANALYZE=
