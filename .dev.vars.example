# Copy to `.dev.vars` for `wrangler dev` (gitignored).
#
# Platform bindings (KV, Queues, …) are declared in wrangler.jsonc — optional snippets:
# config/wrangler.optional-bindings.jsonc (merge only what you provision; none required).
#
# Same binding names + descriptions as `config/cloudflare.bindings.json` → `package.json`
# → `cloudflare` after `pnpm sync:cloudflare-bindings`.
# https://developers.cloudflare.com/workers/platform/deploy-buttons/#worker-environment-variables-and-secrets
#
# `NEXT_PUBLIC_*` — set in `.env` and in Workers **Build** environment (inlined at build).
# D1 / R2 / Images bindings — `wrangler.jsonc`, not here.

# --- Required (production) ---
PAYLOAD_SECRET=replace-with-openssl-rand-hex-32

# --- Optional secrets (same keys as Worker / Build env when used) ---
BLOB_READ_WRITE_TOKEN=
COMMIT_DOCS_API_KEY=
DISCORD_TOKEN=
GA_CREDENTIALS=
GITHUB_ACCESS_TOKEN=
NEXT_PRIVATE_ALGOLIA_API_KEY=
NEXT_PRIVATE_CRON_KEY=
CRON_SECRET=
NEXT_PRIVATE_DRAFT_SECRET=
NEXT_PRIVATE_HUBSPOT_PORTAL_KEY=
NEXT_PRIVATE_RECAPTCHA_SECRET_KEY=
NEXT_PRIVATE_REVALIDATION_KEY=
PAYLOAD_RELEASE_SECRET=
POSTGRES_URL=
DATABASE_URL=
SENDGRID_API_KEY=
STRIPE_SECRET_KEY=

# --- Optional non-secret runtime config ---
PAYLOAD_LOG_LEVEL=
PAYLOAD_CORS_ORIGINS=
COOKIE_DOMAIN=
PAYLOAD_MCP=
PAYLOAD_ECOMMERCE=
PAYLOAD_ECOMMERCE_VARIANTS=
PAYLOAD_MULTI_TENANT=
