{
  "name": "payload-website",
  "version": "1.0.4",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=10.33.2"
  },
  "scripts": {
    "test": "cross-env NODE_OPTIONS=--no-deprecation jest",
    "test:watch": "cross-env NODE_OPTIONS=--no-deprecation jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--no-deprecation jest --coverage",
    "build": "node scripts/build.mjs",
    "build:vercel": "cross-env PAYLOAD_HOSTING=vercel node scripts/build.mjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "pnpm run generate:types:cloudflare && pnpm run generate:types:payload",
    "generate:types:cloudflare": "pnpm exec wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "generate:types:payload": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:llms": "payload run src/scripts/generateLLMs.ts",
    "generate:cursor-rules:payload": "node scripts/generate-payload-cursor-rules.mjs",
    "generate:cursor-rules:next": "node scripts/generate-next-cursor-rules.mjs",
    "generate:cursor-rules": "pnpm run generate:cursor-rules:payload && pnpm run generate:cursor-rules:next",
    "build:skipDocs": "cross-env NODE_OPTIONS=--no-deprecation next build --webpack",
    "postbuild": "next-sitemap --config ./next-sitemap.config.cjs",
    "analyze": "ANALYZE=true next build --webpack",
    "caddy": "caddy run --config Caddyfile",
    "start": "next start",
    "start:unix": "node scripts/next-start-unix.mjs",
    "typegen": "next typegen",
    "lint": "eslint . --fix",
    "prettier:fix": "prettier --write .",
    "migrate-lexical-script": "payload run ./src/migrate.ts",
    "cf:build": "cross-env OPEN_NEXT_INNER_BUILD=1 pnpm exec opennextjs-cloudflare build",
    "cf:populate": "pnpm exec opennextjs-cloudflare populateCache remote",
    "cf:deploy": "pnpm exec opennextjs-cloudflare deploy",
    "preview": "pnpm run cf:build && pnpm exec opennextjs-cloudflare preview",
    "deploy": "pnpm run deploy:database && pnpm run deploy:app",
    "opennext:build": "pnpm generate:llms && cross-env OPEN_NEXT_INNER_BUILD=1 NODE_OPTIONS=--no-deprecation pnpm exec opennextjs-cloudflare build",
    "deploy:app": "pnpm run opennext:build && pnpm exec opennextjs-cloudflare deploy",
    "deploy:database": "node scripts/migrate-production.mjs",
    "workers:build": "pnpm run deploy:database && pnpm run opennext:build",
    "workers:deploy": "pnpm exec opennextjs-cloudflare deploy",
    "upload": "pnpm run cf:build && pnpm exec opennextjs-cloudflare upload",
    "cf-typegen": "pnpm exec wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "deploy:vercel:dry": "node scripts/vercel-config-dry.mjs",
    "deploy:cloudflare:dry": "pnpm run opennext:build && pnpm exec wrangler deploy --dry-run",
    "deploy:dry": "pnpm run deploy:vercel:dry && pnpm run deploy:cloudflare:dry",
    "sync:cloudflare-bindings": "node scripts/sync-cloudflare-bindings.mjs",
    "verify:wiring": "node scripts/verify-payload-wiring.mjs"
  },
  "dependencies": {
    "@docsearch/react": "^3.9.0",
    "@faceless-ui/collapsibles": "^2.0.0-beta.0",
    "@faceless-ui/css-grid": "1.3.0-rc.0",
    "@faceless-ui/modal": "^3.0.0",
    "@faceless-ui/mouse-info": "2.0.0-beta.1",
    "@faceless-ui/scroll-info": "2.0.0",
    "@faceless-ui/slider": "2.0.0-beta.1",
    "@faceless-ui/window-info": "3.0.1",
    "@opennextjs/cloudflare": "^1.19.4",
    "@payloadcms/db-d1-sqlite": "3.84.1",
    "@payloadcms/db-mongodb": "3.84.1",
    "@payloadcms/db-postgres": "3.84.1",
    "@payloadcms/email-nodemailer": "3.84.1",
    "@payloadcms/live-preview-react": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/plugin-ecommerce": "3.84.1",
    "@payloadcms/plugin-form-builder": "3.84.1",
    "@payloadcms/plugin-mcp": "3.84.1",
    "@payloadcms/plugin-multi-tenant": "3.84.1",
    "@payloadcms/plugin-nested-docs": "3.84.1",
    "@payloadcms/plugin-redirects": "3.84.1",
    "@payloadcms/plugin-search": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-r2": "3.84.1",
    "@payloadcms/storage-s3": "3.84.1",
    "@payloadcms/storage-vercel-blob": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-portal": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.1",
    "@sendgrid/mail": "^8.1.4",
    "@stripe/react-stripe-js": "^3.1.1",
    "@stripe/stripe-js": "^1.47.0",
    "@zubricks/plugin-google-analytics": "^1.0.8",
    "algoliasearch": "^4.23.3",
    "cheerio": "^1.2.0",
    "cross-env": "^10.1.0",
    "discord-markdown": "^2.5.1",
    "flatley": "^5.2.0",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "graphql": "^16.13.2",
    "gray-matter": "^4.0.3",
    "instantsearch.js": "^4.95.0",
    "isomorphic-dompurify": "^3.11.0",
    "next": "16.2.4",
    "next-sitemap": "^4.0.6",
    "payload": "3.84.1",
    "prism-react-renderer": "^2.3.1",
    "qs-esm": "7.0.2",
    "react": "19.2.5",
    "react-cookie": "^4.1.1",
    "react-dom": "19.2.5",
    "react-facebook-pixel": "^1.0.4",
    "react-google-recaptcha": "^3.1.0",
    "react-instantsearch": "^7.31.0",
    "react-markdown": "^9.0.1",
    "react-select": "^5.10.2",
    "react-transition-group": "^4.4.5",
    "remark-gfm": "^4.0.0",
    "sass": "^1.99.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^11.11.0",
    "uuid": "10.0.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.2.4",
    "@next/eslint-plugin-next": "16.2.4",
    "@octokit/types": "^9.0.0",
    "@payloadcms/eslint-config": "3.28.0",
    "@payloadcms/eslint-plugin": "3.28.0",
    "@types/cli-progress": "^3.11.0",
    "@types/node": "^22.15.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-google-recaptcha": "^2.1.9",
    "cli-progress": "^3.11.2",
    "dotenv": "^17.4.2",
    "eslint": "9.39.4",
    "prettier": "3.8.3",
    "strip-json-comments": "3.1.1",
    "typescript": "5.8.3",
    "wrangler": "^4.87.0"
  },
  "_futureDependencies": {
    "_comment": "Not installed — JSON cannot use // comments; copy a line into dependencies/devDependencies when you implement the feature.",
    "dependencies": {
      "node-cron": "^3.0.3"
    },
    "devDependencies": {
      "discord.js": "^14.7.1"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "sharp",
      "workerd"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "next": "15 || 16",
        "zod": "4"
      }
    },
    "overrides": {
      "formdata-node": "6.0.3",
      "preact": ">=10.28.2"
    }
  },
  "packageManager": "pnpm@10.33.2",
  "cloudflare": {
    "bindings": {
      "PAYLOAD_SECRET": {
        "description": "**Required** for Payload and for **`pnpm build`** / `payload migrate` in [Workers Builds](https://developers.cloudflare.com/workers/ci-cd/builds/configuration/). Use the **same** value under Worker **Variables & secrets** and **Build variables & secrets**. Generate: `openssl rand -hex 32`. URLs and most integrations belong in **Payload Admin → Globals** after deploy."
      },
      "GITHUB_ACCESS_TOKEN": {
        "description": "**Optional.** GitHub PAT — add under **Build variables & secrets** if you need **`pnpm generate:llms`** to refresh `public/llms*.txt` during CI. See [Deploy buttons — secrets](https://developers.cloudflare.com/workers/platform/deploy-buttons/#worker-environment-variables-and-secrets); dotenv names also appear in `.dev.vars.example`."
      }
    }
  }
}